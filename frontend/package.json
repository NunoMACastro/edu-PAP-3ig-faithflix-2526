{
    "name": "faithflix-frontend",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:check": "vite build --mode test",
        "preview": "vite preview",
        "smoke": "npm run build:check",
        "lint": "eslint . --max-warnings=0",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:contracts": "vitest run src/services/api",
        "validate": "npm run lint && npm run test:unit && npm run build:check"
    },
    "dependencies": {
        "dashjs": "5.2.0",
        "hls.js": "1.6.16",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router-dom": "6.30.4"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.10.2",
        "@eslint/js": "9.39.4",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@vitejs/plugin-react": "6.0.3",
        "eslint": "9.39.4",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "globals": "17.7.0",
        "jsdom": "29.1.1",
        "vite": "8.1.4",
        "vitest": "4.1.10"
    },
    "engines": {
        "node": "^20.19.0 || >=22.13.0"
    }
}
