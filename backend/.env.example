NODE_ENV=development
HOST=127.0.0.1
PORT=3101
SERVICE_NAME=faithflix-api
SESSION_COOKIE_NAME=faithflix_session
FRONTEND_ORIGIN=http://localhost:5181,http://127.0.0.1:5181
# A API e o worker exigem replica set/Atlas para transações multi-documento.
MONGODB_URI=mongodb+srv://<utilizador>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=faithflix_dev
RATE_LIMIT_PEPPER=
FORCE_HTTPS=false
TRUST_PROXY_HOPS=0
BUILD_VERSION=local
WORKER_POLL_MS=60000
MEDIA_STORAGE_ROOT=.local-media
MEDIA_UPLOAD_MAX_BYTES=536870912

# Caixa de email estritamente local. Exige também NODE_ENV=development,
# MONGODB_DB_NAME terminado em `_demo` e pedidos vindos de loopback.
DEMO_MODE=false
ENABLE_DEMO_MAILBOX=false

# Dataset descartável de demonstração. Nunca reutilizar MONGODB_DB_NAME.
# Em alternativa ao Atlas abaixo, aceita-se apenas um replica set local:
# mongodb://127.0.0.1:27017/?replicaSet=faithflix-demo
# Nesse caso a confirmação exata é:
# local-replica-set:faithflix-demo@127.0.0.1:27017/faithflix_demo
DEMO_MONGODB_URI=mongodb+srv://<utilizador>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DEMO_MONGODB_DB_NAME=faithflix_demo
DEMO_RESET_CONFIRM=<cluster>.mongodb.net/faithflix_demo
ALLOW_DEMO_SEED=false
ALLOW_DEMO_RESET=false
ALLOW_DEMO_DATABASE_ADOPTION=false
DEMO_ADMIN_PASSWORD=
DEMO_USER_PASSWORD=
DEMO_REFERENCE_DATE=
DEMO_DATA_SEED=faithflix-demo-v2
ALLOW_ADMIN_PROMOTION=false
ADMIN_PROMOTION_CONFIRM=
